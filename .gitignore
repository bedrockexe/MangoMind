# Umbrella ignore rules for the monorepo (each app also has its own).

# Build / generated
**/build/
**/.dart_tool/
**/.flutter-plugins-dependencies
**/node_modules/

# Secrets & local config
**/serviceAccountKey.json
**/*serviceAccount*.json
**/.env
**/*.local

# Operational scripts (run locally; may contain credentials)
**/functions/change-admin.js
**/functions/delete-all-accounts.js
**/functions/reset-database.js
**/functions/setAdminClaim.js

# Local media that should never be committed
downloads/

# OS / editor
.DS_Store
*.swp
